{
	"info": {
		"_postman_id": "a1b2c3d4-e5f6-7890-1234-56789abcdef0",
		"name": "Bookstore User Service API",
		"description": "Bộ sưu tập đầy đủ tất cả API của Bookstore User Service.\n\n**Hướng dẫn sử dụng:**\n1. Gọi Login hoặc Register để lấy token\n2. Copy giá trị `token` từ response\n3. Dán vào biến `accessToken` trong collection variables\n4. Các API yêu cầu xác thực sẽ tự động dùng token này",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "🔐 Auth",
			"description": "Các API xác thực: đăng ký, đăng nhập, đổi mật khẩu, OTP, xác thực email, refresh token",
			"item": [
				{
					"name": "Register",
					"request": {
						"method": "POST",
						"header": [{"key": "Content-Type", "value": "application/json"}],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"username\": \"testuser\",\n    \"email\": \"testuser@example.com\",\n    \"password\": \"password123\",\n    \"fullName\": \"Test User\",\n    \"phoneNumber\": \"0123456789\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/v1/auth/register",
							"host": ["{{baseUrl}}"],
							"path": ["api", "v1", "auth", "register"]
						}
					}
				},
				{
					"name": "Login",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"var jsonData = pm.response.json();",
									"if (jsonData.result && jsonData.result.token) {",
									"    pm.collectionVariables.set('accessToken', jsonData.result.token);",
									"    console.log('Token saved to accessToken variable');",
									"}",
									"if (jsonData.result && jsonData.result.refreshToken) {",
									"    pm.collectionVariables.set('refreshToken', jsonData.result.refreshToken);",
									"    console.log('Refresh token saved');",
									"}"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [{"key": "Content-Type", "value": "application/json"}],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"username\": \"admin\",\n    \"password\": \"admin\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/v1/auth/login",
							"host": ["{{baseUrl}}"],
							"path": ["api", "v1", "auth", "login"]
						}
					}
				},
				{
					"name": "Change Password",
					"request": {
						"method": "PUT",
						"header": [
							{"key": "Content-Type", "value": "application/json"},
							{"key": "Authorization", "value": "Bearer {{accessToken}}"}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"oldPassword\": \"admin\",\n    \"newPassword\": \"newPassword123\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/v1/auth/change-password",
							"host": ["{{baseUrl}}"],
							"path": ["api", "v1", "auth", "change-password"]
						}
					}
				},
				{
					"name": "Send OTP (Forgot Password)",
					"request": {
						"method": "POST",
						"header": [{"key": "Content-Type", "value": "application/json"}],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"testuser@example.com\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/v1/auth/send-otp",
							"host": ["{{baseUrl}}"],
							"path": ["api", "v1", "auth", "send-otp"]
						}
					}
				},
				{
					"name": "Verify OTP & Reset Password",
					"request": {
						"method": "POST",
						"header": [{"key": "Content-Type", "value": "application/json"}],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"testuser@example.com\",\n    \"otp\": \"123456\",\n    \"newPassword\": \"newPassword123\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/v1/auth/verify-otp",
							"host": ["{{baseUrl}}"],
							"path": ["api", "v1", "auth", "verify-otp"]
						}
					}
				},
				{
					"name": "Send Verification Email",
					"request": {
						"method": "POST",
						"header": [
							{"key": "Content-Type", "value": "application/json"},
							{"key": "Authorization", "value": "Bearer {{accessToken}}"}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"testuser@example.com\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/v1/auth/verify-email",
							"host": ["{{baseUrl}}"],
							"path": ["api", "v1", "auth", "verify-email"]
						}
					}
				},
				{
					"name": "Confirm Email",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/v1/auth/confirm-email?token=YOUR_EMAIL_TOKEN",
							"host": ["{{baseUrl}}"],
							"path": ["api", "v1", "auth", "confirm-email"],
							"query": [{"key": "token", "value": "YOUR_EMAIL_TOKEN"}]
						}
					}
				},
				{
					"name": "Refresh Token",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"var jsonData = pm.response.json();",
									"if (jsonData.result && jsonData.result.token) {",
									"    pm.collectionVariables.set('accessToken', jsonData.result.token);",
									"    console.log('New access token saved');",
									"}"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [{"key": "Content-Type", "value": "application/json"}],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"refreshToken\": \"{{refreshToken}}\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/v1/auth/refresh-token",
							"host": ["{{baseUrl}}"],
							"path": ["api", "v1", "auth", "refresh-token"]
						}
					}
				}
			]
		},
